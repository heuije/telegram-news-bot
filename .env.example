# ─────────────────────────────────────────────────────────────
# .env.example  —  이 파일을 .env로 복사하고 값을 채우세요.
#   PowerShell:  Copy-Item .env.example .env
#   Linux:       cp .env.example .env
# .env 파일은 절대 git/공유에 올리지 마세요 (.gitignore에 포함됨)
# ─────────────────────────────────────────────────────────────

# Telegram BotFather (@BotFather → /newbot 또는 /token)에서 발급
TELEGRAM_TOKEN=여기에_새로_발급받은_봇_토큰

# 메시지를 받을 채팅의 chat_id (개인 채팅이면 본인 user id)
# 확인 방법: 봇과 대화 시작 후 https://api.telegram.org/bot<TOKEN>/getUpdates 호출
TELEGRAM_CHAT_ID=여기에_숫자_chat_id

# Anthropic 콘솔 (https://console.anthropic.com/settings/keys)에서 발급
ANTHROPIC_API_KEY=sk-ant-api03-여기에_새로_발급받은_키

# DART(전자공시) Open API 키 — https://opendart.fss.or.kr 에서 무료 발급
DART_API_KEY=여기에_DART_API_키
